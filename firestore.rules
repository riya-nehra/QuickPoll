// firestore.rules
// Copy-paste these rules into Firebase Console → Firestore → Rules
// Then click "Publish"

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /polls/{pollId} {
      // ── Read: anyone can read any poll ───────────────────────────────────
      allow read: true;

      // ── Create: anyone can create a poll (auth optional) ─────────────────
      allow create: if request.resource.data.question is string
                    && request.resource.data.question.size() > 0
                    && request.resource.data.options is map
                    && request.resource.data.options.size() >= 2;

      // ── Update: only vote-related fields can be changed without auth ──────
      // This prevents someone from overwriting the question or options.
      allow update: if request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['options', 'totalVotes']);
    }
  }
}
